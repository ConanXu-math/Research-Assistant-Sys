# Research Assistant Sys 环境变量模板
# 复制为 .env 并编辑:
#   Windows:  copy .env.example .env
#   Unix:     cp .env.example .env
#
# 程序读取 OPTIBENCH_*；官方 OpenAI 也可使用环境变量 OPENAI_API_KEY。
# 若习惯命名 LLM_API_KEY / LLM_BASE_URL / LLM_MODEL_ID，请对应填入:
#   OPTIBENCH_API_KEY / OPTIBENCH_BASE_URL / OPTIBENCH_MODEL

# ========== LLM ==========
# 提供商: openai | openai-like | ollama | anthropic | google
#
# openai        — OpenAI；密钥: OPTIBENCH_API_KEY 或 OPENAI_API_KEY
# openai-like   — OpenAI 兼容 HTTP API；须设置 OPTIBENCH_BASE_URL 与 OPTIBENCH_API_KEY
# ollama        — 本地 Ollama，默认 http://localhost:11434/v1，可不设 Key
#
OPTIBENCH_PROVIDER=openai
OPTIBENCH_MODEL=gpt-4o
OPTIBENCH_BASE_URL=
OPTIBENCH_API_KEY=
OPTIBENCH_API_TIMEOUT=
OPTIBENCH_LOG_JSON=0
OPTIBENCH_WORKERS=1

# openai-like 示例（请替换为你的网关；勿将真实 Key 提交到 git）
# OPTIBENCH_PROVIDER=openai-like
# OPTIBENCH_MODEL=your-model-id
# OPTIBENCH_BASE_URL=https://example.edu.cn/open/api/v1
# OPTIBENCH_API_KEY=sk-your-key

# ========== Agno 流水线（可选）==========
# 默认使用 agno.workflow.Workflow 编排五步；若需旧版顺序执行（调试用）:
# OPTIBENCH_LEGACY_PIPELINE=1
# 允许 Agno Workflow 匿名遥测（默认关闭）:
# OPTIBENCH_AGNO_TELEMETRY=1

# 抽取策略: unified（默认）| locator_first（强制先 Locator）| auto（按长度与公式密度自动切换）
# OPTIBENCH_EXTRACTION_STRATEGY=unified
# auto 模式阈值（可选）
# OPTIBENCH_LOCATOR_MIN_CHARS=12000
# OPTIBENCH_LOCATOR_MIN_MATH_MARKERS=40

# ========== 代理（可选）==========
# 无法访问 arXiv / OCR / LLM 时配置；requests 会读取这些变量。
HTTP_PROXY=
HTTPS_PROXY=

# ========== arXiv（搜索/下载）==========
# 超时或连不上时可配合上方代理；诊断: python scripts/diagnose_arxiv_connection.py
OPTIBENCH_ARXIV_TIMEOUT=120
OPTIBENCH_ARXIV_BASE_URL=

# ========== PDF → Markdown ==========
# OPTIBENCH_PDF_BACKEND:
#   pypdf    — 默认，pypdf 抽文本（扫描版 PDF 效果差）
#   marker   — 需安装: uv pip install -e ".[marker]"
#   nougat   — 需安装: uv pip install -e ".[nougat]"
#   mineru   — 走 MinerU API（本地文件上传 -> 轮询 -> 下载 zip -> 读取 full.md）
#            兼容旧别名: http-ocr | http_ocr | remote-ocr | remote_ocr
#
OPTIBENCH_PDF_BACKEND=pypdf
OPTIBENCH_MINERU_TOKEN=
OPTIBENCH_MINERU_MODEL_VERSION=vlm
OPTIBENCH_MINERU_TIMEOUT=120
OPTIBENCH_MINERU_POLL_INTERVAL=3
OPTIBENCH_MINERU_POLL_TIMEOUT=300

# MinerU 示例
# OPTIBENCH_PDF_BACKEND=mineru
# OPTIBENCH_MINERU_TOKEN=your_token

# ========== 其它超时与路径 ==========
OPTIBENCH_MARKER_TIMEOUT=300
OPTIBENCH_NOUGAT_TIMEOUT=300
OPTIBENCH_PY_TIMEOUT=120
OPTIBENCH_LEAN_TIMEOUT=300
OPTIBENCH_LEAN_PROJECT_DIR=
OPTIBENCH_EXTRACT_MAX_CHARS=24000
